[global]
    # -- Vị trí & Kích thước --
    origin = top-right
    offset = (20, 20)
    width = 320
    height = (0, 350)
    
    # -- Giao diện (Modern UI) --
    corner_radius = 12
    frame_width = 2
    gap_size = 8
    
    # -- Khoảng cách (Padding) --
    padding = 18
    horizontal_padding = 18
    text_icon_padding = 20
    
    # -- Text & Font --
    # Sử dụng font hỗ trợ tốt các ký tự Nerd Fonts
    font = "JetBrains Mono Nerd Font 10, Noto Sans 10"
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    
    # -- Quản lý hiển thị --
    notification_limit = 5
    idle_threshold = 120
    show_age_threshold = 60
    word_wrap = yes
    ignore_newline = no
    
    # -- Cấu hình Icon & Hình ảnh --
    enable_recursive_icon_lookup = true
    icon_theme = "Papirus-Dark,Papirus,Adwaita"
    icon_position = left
    min_icon_size = 64
    max_icon_size = 80
    icon_corner_radius = 8

    progress_bar = true
    progress_bar_height = 8          # Làm thanh bar cực mỏng (từ 8 xuống 4)
    progress_bar_frame_width = 0     # Xóa viền đen thô kệch bao quanh thanh bar
    #progress_bar_min_width = 200     # Độ dài cố định trông sẽ liền mạch hơn
    #progress_bar_max_width = 200
    highlight = "#88C0D0"
    progress_bar_corner_radius = 4

# -- Phân loại mức độ thông báo (Theme Catppuccin Mocha) --

[urgency_low]
    background = "#2E3440"
    foreground = "#ECEFF4"
    frame_color = "#81A1C1"
    timeout = 4

[urgency_normal]
    background = "#2E3440"
    foreground = "#D8DEE9"
    frame_color = "#5E81AC"
    timeout = 6

[urgency_critical]
    background = "#2E3440"
    foreground = "#BF616A"
    frame_color = "#BF616A"
    timeout = 0

# -- Các quy tắc tùy chỉnh (Rules) --

[dev_tools]
    appname = "code"
    summary = "*Flutter*|*Spring Boot*|*Golang*|*Csharp*|*Rust*|*Python*|*Java*|*Typescript*"
    frame_color = "#A3BE8C" # Xanh rêu/bạc hà lạnh
    timeout = 8

[gaming_mode]
    appname = "steam_app_*"
    fullscreen = pushback